---
import type { Locale } from "@i18n/types";

interface Props {
  locale: Locale;
  label: string;
}

const { locale, label } = Astro.props;
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : `${raw}/`;
const targetHref = locale === "en" ? `${base}he/` : base;
---

<a
  href={targetHref}
  class="inline-flex items-center justify-center rounded-full border border-white/25 px-3.5 py-2 text-[0.875rem] font-semibold text-white transition-colors duration-150 hover:bg-white/15"
  aria-label={label}
>
  {label}
</a>

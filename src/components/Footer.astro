---
import type { Locale, Translations } from "@i18n/types";
import logo from "@assets/logo.svg";
import { Mail, Phone, MapPin } from "@lucide/astro";

interface Props {
  t: Translations;
  locale: Locale;
}

const { t, locale } = Astro.props;

const year = new Date().getFullYear();
const copyright = t.footer.copyright.replace("{year}", String(year));
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : `${raw}/`;
const homeHref = locale === "en" ? `${base}en/` : base;
const localePath = locale === "en" ? `${base}en/` : base;

const navLinks = [
  { label: t.nav.services, href: `${homeHref}#services` },
  { label: t.nav.process, href: `${homeHref}#process` },
  { label: t.nav.industries, href: `${homeHref}#industries` },
  { label: t.nav.about, href: `${homeHref}#about` },
  { label: t.nav.contact, href: `${homeHref}#contact` },
];

const legalLinks = [
  { label: t.footer.privacyPolicy, href: `${localePath}privacy/` },
  { label: t.footer.termsOfService, href: `${localePath}terms/` },
  { label: t.footer.cookiePolicy, href: `${localePath}cookies/` },
  { label: t.footer.accessibility, href: `${localePath}accessibility/` },
];
---

<footer class="relative bg-dark px-6 lg:px-12 noise-texture overflow-hidden">
  <!-- Top accent line -->
  <div class="absolute top-0 left-0 right-0 section-divider" aria-hidden="true"></div>

  <!-- Ambient glow -->
  <div
    class="absolute bottom-0 start-0 w-[400px] h-[300px] rounded-full"
    style="background: radial-gradient(ellipse, rgba(224, 104, 90, 0.06) 0%, transparent 65%);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-[72rem] pt-16 pb-8 lg:pt-20">
    <!-- Main footer grid -->
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1.4fr_0.8fr] lg:gap-10">

      <!-- Brand column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={homeHref} aria-label="NLX-labs home">
          <img src={logo.src} alt="NLX Labs" class="h-10 w-auto" />
        </a>
        <p class="mt-4 text-[0.875rem] leading-relaxed text-dark-text-secondary max-w-[32ch]">
          {t.footer.tagline}
        </p>
        <p class="mt-5 inline-flex items-center gap-2 text-[0.8125rem] text-white/40">
          <MapPin size={14} class="flex-shrink-0" aria-hidden="true" />
          {t.footer.location}
        </p>
      </div>

      <!-- Navigation column -->
      <div>
        <h3 class="footer-heading">
          {t.footer.navigationTitle}
        </h3>
        <ul class="space-y-2.5">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal column -->
      <div>
        <h3 class="footer-heading">
          {t.footer.legalTitle}
        </h3>
        <ul class="space-y-2.5">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="footer-heading">
          {t.footer.contactTitle}
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="mailto:contact@nlx-labs.com" class="footer-link inline-flex items-center gap-2">
              <Mail size={14} class="flex-shrink-0" aria-hidden="true" />
              contact@nlx-labs.com
            </a>
          </li>
          <li>
            <a href="tel:+972509927121" class="footer-link inline-flex items-center gap-2" dir="ltr">
              <Phone size={14} class="flex-shrink-0" aria-hidden="true" />
              +972-50-992-7121
            </a>
          </li>
          <li>
            <a
              href="https://wa.me/972509927121"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link inline-flex items-center gap-2"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.96 7.96 0 01-4.11-1.14l-.29-.174-3.01.79.81-2.95-.19-.3A7.96 7.96 0 014 12c0-4.42 3.58-8 8-8s8 3.58 8 8-3.58 8-8 8z"/>
              </svg>
              {t.footer.whatsappChat}
            </a>
          </li>
        </ul>
      </div>

      <!-- Follow Us column -->
      <div>
        <h3 class="footer-heading">{t.footer.followTitle}</h3>
        <a
          href="https://www.linkedin.com/company/nlxlabsai/"
          target="_blank"
          rel="noopener noreferrer"
          class="linkedin-link inline-flex items-center gap-2"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="flex-shrink-0">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          <span class="text-[0.875rem]">LinkedIn</span>
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-14 pt-6 border-t border-white/[0.07]">
      <p class="text-center text-[0.8125rem] text-white/40">
        {copyright}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-heading {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1rem;
  }

  .footer-link {
    font-size: 0.875rem;
    line-height: 1;
    color: var(--color-dark-text-secondary);
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: var(--color-dark-text);
  }

  .linkedin-link {
    color: var(--color-dark-text-secondary);
    transition: color 0.15s ease;
  }

  .linkedin-link:hover {
    color: #0A66C2;
  }
</style>

---
interface Props {
  variant?: "primary" | "secondary" | "ghost";
  href?: string;
  type?: "button" | "submit";
  class?: string;
  ariaLabel?: string;
}

const { variant = "primary", href, type = "button", class: className = "", ariaLabel } = Astro.props;

const baseClasses = "inline-flex items-center justify-center min-h-[48px] px-7 rounded-[0.5rem] font-medium text-[0.9375rem] leading-none transition-all duration-150 cursor-pointer";

const variantClasses = {
  primary: "bg-accent text-white hover:bg-accent-hover",
  secondary: "bg-transparent border border-white/25 text-white hover:bg-white/10",
  ghost: "bg-transparent text-accent hover:underline underline-offset-4",
};

const classes = `${baseClasses} ${variantClasses[variant]} ${className}`.trim();
---

{href ? (
  <a href={href} class={classes} aria-label={ariaLabel}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} aria-label={ariaLabel}>
    <slot />
  </button>
)}

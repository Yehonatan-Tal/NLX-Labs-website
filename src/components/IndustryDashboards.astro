    .ind-pill { scroll-snap-align: start; flex-shrink: 0; }
    .ind-pills-fade-start, .ind-pills-fade-end { display: block; position: absolute; top: 0; bottom: 0; width: 32px; pointer-events: none; z-index: 1; }
    .ind-pills-fade-start { left: 0; background: linear-gradient(to right, #07080a, transparent); }
    .ind-pills-fade-end { right: 0; background: linear-gradient(to left, #07080a, transparent); }
  }
  @media (min-width: 769px) { .ind-pills-fade-start, .ind-pills-fade-end { display: none; } }

  /* ── Content & Panels ── */
  .ind-content { position: relative; }

    .ind-chart-line { stroke-dasharray: none; stroke-dashoffset: 0; transition: none; }
    .ind-chart-area { opacity: 1; transition: none; }
    .ind-donut-fill { transition: none; }
    .ind-gauge-fill { transition: none; }
    .ind-funnel-stage { transition: none; }
    .ind-slot { transition: none; }
    .ind-frame { animation: none; }
  }
</style>

<script>
  import gsap from "gsap";

  function initIndustryExplorer() {
    const section = document.querySelector<HTMLElement>("[data-industry-section]");
    if (!section) return;

    const pills = section.querySelectorAll<HTMLButtonElement>(".ind-pill");
    const contentWrap = section.querySelector<HTMLElement>("[data-industry-content]");
    const panels = section.querySelectorAll<HTMLElement>("[data-industry-panel]");
    const tablist = section.querySelector<HTMLElement>(".ind-pills");

    if (!contentWrap || panels.length === 0) return;

    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let current = -1;
    let loopTimers: number[] = [];

    // ── Counter formatting ──
    function formatCount(value: number, format: string): string {
      if (format === "money-k") return "$" + (value / 1000).toFixed(1) + "K";
      if (format === "money-m") return "$" + (value / 1000000).toFixed(1) + "M";
      return value.toLocaleString("en-US");
    }

    // ── Stop all running loops ──
    function stopLoops() {
      loopTimers.forEach((id) => clearInterval(id));
      loopTimers = [];
    }

    // ── Feed cycling ──
    function startFeed(container: HTMLElement): number {
      const items = Array.from(container.querySelectorAll<HTMLElement>(".ind-feed-item"));
      if (items.length <= 4) return 0;

      const visible = 4;
      let offset = 0;

      // Initial: show first 4
      items.forEach((item, i) => {
        item.style.display = i < visible ? "" : "none";
        item.style.opacity = "1";
      });

      return window.setInterval(() => {
        const fadeOut = items[offset % items.length];
        fadeOut.style.transition = "opacity 0.3s ease-out";
        fadeOut.style.opacity = "0";

        setTimeout(() => {
          fadeOut.style.display = "none";
          offset++;
          const fadeIn = items[(offset + visible - 1) % items.length];
          fadeIn.style.display = "";
          fadeIn.style.opacity = "0";
          requestAnimationFrame(() => {
            fadeIn.style.transition = "opacity 0.4s ease-in";
            fadeIn.style.opacity = "1";
          });
        }, 300);
      }, 4000);
    }

    // ── Start looping animations for active panel ──
    function startLoops(index: number) {
      stopLoops();
      const panel = panels[index];
      if (!panel) return;

      // Counters
      panel.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
        let val = parseInt(el.getAttribute("data-count") || "0", 10);
        const step = parseInt(el.getAttribute("data-count-step") || "1", 10);
        const format = el.getAttribute("data-count-format") || "int";

        const timer = window.setInterval(() => {
          val += step + Math.floor(Math.random() * step);
          el.textContent = formatCount(val, format);
          el.setAttribute("data-count", String(val));
        }, 3500 + Math.random() * 1500);
        loopTimers.push(timer);
      });

      // Feeds
      panel.querySelectorAll<HTMLElement>("[data-feed]").forEach((feed) => {
        const timer = startFeed(feed);
        if (timer) loopTimers.push(timer);
      });

      // Donut wobble
      panel.querySelectorAll<SVGCircleElement>("[data-donut-fill]").forEach((circle) => {
        const base = parseFloat(circle.getAttribute("data-donut-base") || "0");
        const timer = window.setInterval(() => {
          const wobble = base + (Math.random() - 0.5) * 3;
          circle.style.strokeDashoffset = String(Math.max(0, wobble));
        }, 6000 + Math.random() * 2000);
        loopTimers.push(timer);
      });

      // Gauge wobble
      panel.querySelectorAll<SVGPathElement>("[data-gauge-fill]").forEach((path) => {
        const base = parseFloat(path.getAttribute("data-gauge-base") || "0");
        const timer = window.setInterval(() => {
          const wobble = base + (Math.random() - 0.5) * 1.5;
          path.style.strokeDashoffset = String(Math.max(0, wobble));
        }, 5000 + Math.random() * 2000);
        loopTimers.push(timer);
      });

      // Slot grid fill (healthcare)
      panel.querySelectorAll<HTMLElement>("[data-slot-grid]").forEach((grid) => {
        const emptySlots = Array.from(grid.querySelectorAll(".ind-slot:not(.ind-slot-filled):not(.ind-slot-ai)"));
        let idx = 0;
        if (emptySlots.length > 0) {
          const timer = window.setInterval(() => {
            if (idx < emptySlots.length) {
              emptySlots[idx].classList.add("ind-slot-ai");
              idx++;
            }
          }, 5000);
          loopTimers.push(timer);
        }
      });
    }

    // ── Show a panel ──
    function showPanel(index: number) {
      if (index === current) return;

      // Update pills
      pills.forEach((p, i) => p.setAttribute("aria-selected", i === index ? "true" : "false"));

      // First reveal — show content wrapper
      if (current === -1) {
        contentWrap!.removeAttribute("hidden");
      }

      // Hide all panels
      panels.forEach((p) => p.setAttribute("hidden", ""));

      // Show selected panel
      const panel = panels[index];
      if (!panel) return;
      panel.removeAttribute("hidden");

      const isFirst = current === -1;
      current = index;

      // Stop old loops, start new
      stopLoops();

      if (prefersReduced) return;

      // GSAP animation
      const duration = isFirst ? 0.5 : 0.35;
      const yFrom = isFirst ? 20 : 8;
      gsap.fromTo(panel, { opacity: 0, y: yFrom }, { opacity: 1, y: 0, duration, ease: "power2.out" });

      // Start loops after initial animation
      setTimeout(() => startLoops(index), duration * 1000 + 200);
    }

    // ── Event listeners ──
    pills.forEach((pill, i) => {
      pill.addEventListener("click", () => showPanel(i));
    });

    if (tablist) {
      tablist.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
          e.preventDefault();
          const dir = e.key === "ArrowRight" ? 1 : -1;
          const next = current < 0 ? 0 : (current + dir + pills.length) % pills.length;
          showPanel(next);
          pills[next]?.focus();
        }
      });
    }

    // ── Lock content height ──
    function lockContentHeight() {
      if (window.innerWidth < 769) { contentWrap!.style.minHeight = ""; return; }
      const wasHidden = contentWrap!.hasAttribute("hidden");
      if (wasHidden) contentWrap!.removeAttribute("hidden");

      let maxH = 0;
      panels.forEach((panel) => {
        const wasH = panel.hasAttribute("hidden");
        panel.removeAttribute("hidden");
        panel.style.position = "relative";
        maxH = Math.max(maxH, panel.offsetHeight);
        panel.style.position = "";
        if (wasH) panel.setAttribute("hidden", "");
      });

      if (wasHidden) contentWrap!.setAttribute("hidden", "");
      contentWrap!.style.minHeight = maxH + "px";
    }

    lockContentHeight();
    if (document.fonts?.ready) document.fonts.ready.then(lockContentHeight);
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => { clearTimeout(resizeTimer); resizeTimer = setTimeout(lockContentHeight, 250); });

    // Auto-select first industry on load
    showPanel(0);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initIndustryExplorer);
  } else {
    initIndustryExplorer();
  }
</script>

                      </div>
                      <div class="ind-widget-footnote">94% utilization · <span class="ind-dim">was 67%</span></div>
                    </div>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Claims Pipeline</div>
                      <div class="ind-funnel">
                        <div class="ind-funnel-stage" style="--w:100%;--a:0.15"><span>Submitted</span><span>847</span></div>
                        <div class="ind-funnel-stage" style="--w:80%;--a:0.2"><span>Validated</span><span>678</span></div>
                        <div class="ind-funnel-stage" style="--w:68%;--a:0.28"><span>Approved</span><span>576</span></div>
                        <div class="ind-funnel-stage" style="--w:60%;--a:0.35"><span>Paid</span><span>508</span></div>
                      </div>
                      <div class="ind-compare" style="margin-top:10px">
                        <div class="ind-compare-row">
                          <span class="ind-compare-label">Manual</span>
                          <div class="ind-compare-track"><div class="ind-compare-fill" style="--bar-w:100%"></div></div>
                          <span class="ind-compare-val">8.4 days</span>
                        </div>
                        <div class="ind-compare-row">
                          <span class="ind-compare-label">AI</span>
                          <div class="ind-compare-track"><div class="ind-compare-fill ind-compare-accent" style="--bar-w:14%"></div></div>
                          <span class="ind-compare-val">1.2 days</span>
                        </div>
                      </div>
                    </div>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Patient Automation</div>
                      <div class="ind-hero-num" data-count="847" data-count-step="2" data-count-format="int">847</div>
                      <div class="ind-hero-unit">touchpoints today</div>
                      <div class="ind-feed" data-feed style="margin-top:8px">
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">&#10003;</span><span class="ind-feed-text">Reminder → A. Mizrahi — Appt 9:30</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">&#10003;</span><span class="ind-feed-text">Rx refill → D. Peretz — Metformin</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">&#10003;</span><span class="ind-feed-text">Lab ready → B. Stein — CBC panel</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">&#10003;</span><span class="ind-feed-text">Follow-up → Y. Katz — Post-op Day 7</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">&#10003;</span><span class="ind-feed-text">Pre-visit → R. Levy — Forms sent</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">&#10003;</span><span class="ind-feed-text">Verified → S. Cohen — Insurance OK</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">&#10003;</span><span class="ind-feed-text">Recall → M. Friedman — Flu vaccine</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">&#10003;</span><span class="ind-feed-text">Survey → T. Shapira — Satisfaction</span></div>
                      </div>
                      <div class="ind-savings" style="margin-top:8px">
                        <span class="ind-savings-value">$12K</span>
                        <span class="ind-savings-label">monthly savings · No-show: 4%</span>
                      </div>
                    </div>
                  </>
                )}

                {/* ── Industry 5: Government & Municipal ── */}
                {i === 5 && (
                  <>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Citizen Services</div>

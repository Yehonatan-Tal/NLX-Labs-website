  .ind-bar { height: 5px; background: rgba(255,255,255,0.06); border-radius: 3px; overflow: hidden; }
  .ind-bar-fill { height: 100%; width: 0; background: linear-gradient(90deg, var(--color-accent), #f0917e); border-radius: 3px; transition: width 0.8s ease-out; box-shadow: 0 0 6px rgba(224,104,90,0.3); }

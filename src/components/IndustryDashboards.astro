  .ind-savings-label { font-size: 10px; color: var(--color-dark-text-secondary); }

  /* ── Metric Bars (reused) ── */
  .ind-metric-row { display: flex; justify-content: space-between; font-size: 11px; color: var(--color-dark-text-secondary); margin-bottom: 4px; margin-top: 6px; }

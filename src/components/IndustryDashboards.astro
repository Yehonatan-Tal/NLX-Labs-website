---
import { Truck, GraduationCap, ChartBar, Scale, HeartPulse, Landmark, ShoppingCart } from "@lucide/astro";

interface Props {
  items: Array<{ name: string; bullets: string[] }>;
}

const { items } = Astro.props;

const icons: Record<number, any> = {
  0: Truck,
  1: GraduationCap,
  2: ChartBar,
  3: Scale,
  4: HeartPulse,
  5: Landmark,
  6: ShoppingCart,
};
---

<div data-industry-section>
  <!-- Pill row -->
  <div class="ind-pills-wrap">
    <div class="ind-pills" role="tablist" aria-label="Industry selector">
      {items.map((item, i) => {
        const Icon = icons[i];
        return (
          <button class="ind-pill" role="tab" aria-selected="false" data-industry={i}>
            {Icon && <Icon size={16} aria-hidden="true" />}
            <span>{item.name}</span>
          </button>
        );
      })}
    </div>
    <div class="ind-pills-fade-start" aria-hidden="true"></div>
    <div class="ind-pills-fade-end" aria-hidden="true"></div>
  </div>

  <!-- Content area -->
  <div class="ind-content" data-industry-content hidden>
    {items.map((item, i) => {
      const Icon = icons[i];
      return (
        <div class="ind-panel" data-industry-panel={i} role="tabpanel" hidden>
          <div class="ind-layout">
            <div class="ind-frame">
            <div class="ind-dashboard" dir="ltr">
              <div class="ind-app-header">
                <div class="ind-app-header-start">
                  {Icon && <Icon size={16} class="ind-app-icon" aria-hidden="true" />}
                  <span class="ind-app-name">{item.name}</span>
                </div>
                <div class="ind-app-header-end">
                  <span class="ind-status-dot" aria-hidden="true"></span>
                  <span class="ind-status-text">AI Active</span>
                  <span class="ind-app-badge">NLX</span>
                </div>
              </div>

              <div class="ind-app-body">
                {/* ── Industry 0: Logistics & Customs ── */}
                {i === 0 && (
                  <>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Document Processing</div>
                      <div class="ind-hero-num" data-count="2847" data-count-step="3" data-count-format="int">2,847</div>
                      <div class="ind-hero-unit">documents processed today</div>
                      <svg class="ind-area-chart" viewBox="0 0 200 80" fill="none" aria-hidden="true">
                        <defs><linearGradient id="ig0" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.3"/><stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0"/></linearGradient></defs>
                        <path d="M0,72 L18,61 36,45 55,28 73,17 91,8 109,12 127,15 145,10 164,21 182,38 200,55 L200,80 L0,80Z" fill="url(#ig0)" class="ind-chart-area"/>
                        <polyline points="0,72 18,61 36,45 55,28 73,17 91,8 109,12 127,15 145,10 164,21 182,38 200,55" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ind-chart-line"/>
                      </svg>
                      <div class="ind-widget-footnote">12 sec avg · <span class="ind-dim">Manual: 4.2 hrs</span></div>
                    </div>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Cost per Shipment</div>
                      <div class="ind-compare">
                        <div class="ind-compare-row">
                          <span class="ind-compare-label">Manual</span>
                          <div class="ind-compare-track"><div class="ind-compare-fill" style="--bar-w:100%"></div></div>
                          <span class="ind-compare-val">$340</span>
                        </div>
                        <div class="ind-compare-row">
                          <span class="ind-compare-label">AI</span>
                          <div class="ind-compare-track"><div class="ind-compare-fill ind-compare-accent" style="--bar-w:3.5%"></div></div>
                          <span class="ind-compare-val">$12</span>
                        </div>
                      </div>
                      <div class="ind-savings">
                        <span class="ind-savings-value" data-count="18400" data-count-step="100" data-count-format="money-k">$18.4K</span>
                        <span class="ind-savings-label">saved this month</span>
                      </div>
                    </div>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Live Processing</div>
                      <div class="ind-feed" data-feed>
                        <div class="ind-feed-item"><span class="ind-feed-time">14:32</span><span class="ind-feed-text">Bill of Lading #4891 — classified</span><span class="ind-feed-badge">0.3s</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-time">14:32</span><span class="ind-feed-text">Invoice #2847 — validated</span><span class="ind-feed-badge">0.5s</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-time">14:31</span><span class="ind-feed-text">Customs Form HK-2103 — processed</span><span class="ind-feed-badge">0.4s</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-time">14:31</span><span class="ind-feed-text">Packing List #7234 — verified</span><span class="ind-feed-badge">0.2s</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-time">14:30</span><span class="ind-feed-text">Certificate of Origin — matched</span><span class="ind-feed-badge">0.6s</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-time">14:30</span><span class="ind-feed-text">HS Code 8471.30 — auto-assigned</span><span class="ind-feed-badge">0.1s</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-time">14:29</span><span class="ind-feed-text">Duty Calc #3891 — completed</span><span class="ind-feed-badge">0.3s</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-time">14:29</span><span class="ind-feed-text">Sanction Screen #8842 — cleared</span><span class="ind-feed-badge">0.2s</span></div>
                      </div>
                    </div>
                  </>
                )}

                {/* ── Industry 1: Education ── */}
                {i === 1 && (
                  <>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Grading Engine</div>
                      <div class="ind-hero-num" data-count="1247" data-count-step="2" data-count-format="int">1,247</div>
                      <div class="ind-hero-unit">assessments graded today</div>
                      <svg class="ind-area-chart" viewBox="0 0 200 80" fill="none" aria-hidden="true">
                        <defs><linearGradient id="ig1" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.25"/><stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0"/></linearGradient></defs>
                        <path d="M0,8 L22,35 44,48 67,55 89,68 111,15 133,28 155,42 178,52 200,65 L200,80 L0,80Z" fill="url(#ig1)" class="ind-chart-area"/>
                        <polyline points="0,8 22,35 44,48 67,55 89,68 111,15 133,28 155,42 178,52 200,65" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ind-chart-line"/>
                      </svg>
                      <div class="ind-widget-footnote">0.8s per assessment · <span class="ind-dim">Manual: 12 min</span></div>
                    </div>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Early Detection</div>
                      <div class="ind-compare">
                        <div class="ind-compare-row">
                          <span class="ind-compare-label">Manual</span>
                          <div class="ind-compare-track"><div class="ind-compare-fill" style="--bar-w:100%"></div></div>
                          <span class="ind-compare-val">Week 9</span>
                        </div>
                        <div class="ind-compare-row">
                          <span class="ind-compare-label">AI</span>
                          <div class="ind-compare-track"><div class="ind-compare-fill ind-compare-accent" style="--bar-w:33%"></div></div>
                          <span class="ind-compare-val">Week 3</span>
                        </div>
                      </div>
                      <div class="ind-indicator-row" style="margin-top:10px"><span class="ind-indicator" style="background:#28c840"></span><span>89% intervention success rate</span></div>
                      <div class="ind-indicator-row"><span class="ind-indicator" style="background:var(--color-accent)"></span><span>23 hrs/week returned to teaching</span></div>
                    </div>
                    <div class="ind-widget ind-widget-donut">
                      <div class="ind-widget-label">Admin Automation</div>
                      <svg viewBox="0 0 80 80" class="ind-donut" aria-hidden="true">
                        <circle cx="40" cy="40" r="30" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="7"/>
                        <circle cx="40" cy="40" r="30" fill="none" stroke="var(--color-accent)" stroke-width="7" stroke-linecap="round" class="ind-donut-fill" stroke-dasharray="188.5" stroke-dashoffset="188.5" data-donut-fill data-donut-base="62.2" style="--donut-offset:62.2" transform="rotate(-90 40 40)"/>
                        <text x="40" y="37" text-anchor="middle" dominant-baseline="central" fill="var(--color-accent)" font-size="18" font-weight="700">67%</text>
                        <text x="40" y="52" text-anchor="middle" fill="rgba(150,160,180,0.7)" font-size="8">automated</text>
                      </svg>
                      <div class="ind-indicator-row"><span class="ind-indicator" style="background:#28c840"></span><span>Teacher satisfaction: +34%</span></div>
                    </div>
                  </>
                )}

                {/* ── Industry 2: Financial Services ── */}
                {i === 2 && (
                  <>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Transaction Screening</div>
                      <div class="ind-hero-num" data-count="12847" data-count-step="5" data-count-format="int">12,847</div>
                      <div class="ind-hero-unit">screened today</div>
                      <svg class="ind-area-chart" viewBox="0 0 200 80" fill="none" aria-hidden="true">
                        <defs><linearGradient id="ig2" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.3"/><stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0"/></linearGradient></defs>
                        <path d="M0,71 L29,74 57,66 86,6 114,21 143,11 171,46 200,66 L200,80 L0,80Z" fill="url(#ig2)" class="ind-chart-area"/>
                        <polyline points="0,71 29,74 57,66 86,6 114,21 143,11 171,46 200,66" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ind-chart-line"/>
                      </svg>
                      <div class="ind-widget-footnote">3 flagged · 0 false positives</div>
                    </div>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Analyst Efficiency</div>
                      <div class="ind-hero-num" data-count="340" data-count-step="1" data-count-format="int">340</div>
                      <div class="ind-hero-unit">analyst-hours saved this month</div>
                      <div class="ind-compare" style="margin-top:10px">
                        <div class="ind-compare-row">
                          <span class="ind-compare-label">Automated</span>
                          <div class="ind-compare-track"><div class="ind-compare-fill ind-compare-accent" style="--bar-w:94%"></div></div>
                          <span class="ind-compare-val">94%</span>
                        </div>
                        <div class="ind-compare-row">
                          <span class="ind-compare-label">Manual</span>
                          <div class="ind-compare-track"><div class="ind-compare-fill" style="--bar-w:6%"></div></div>
                          <span class="ind-compare-val">6%</span>
                        </div>
                      </div>
                      <div class="ind-savings">
                        <span class="ind-savings-value">$2.1M</span>
                        <span class="ind-savings-label">prevented losses YTD</span>
                      </div>
                    </div>
                    <div class="ind-widget ind-widget-gauge">
                      <div class="ind-widget-label">Detection Accuracy</div>
                      <svg viewBox="0 0 120 70" class="ind-gauge" aria-hidden="true">
                        <path d="M15,60 A45,45 0 0,1 105,60" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="8" stroke-linecap="round"/>
                        <path d="M15,60 A45,45 0 0,1 105,60" fill="none" stroke="#28c840" stroke-width="8" stroke-linecap="round" class="ind-gauge-fill" stroke-dasharray="141" stroke-dashoffset="141" data-gauge-fill data-gauge-base="0.4" style="--gauge-offset:0.4"/>
                        <text x="60" y="48" text-anchor="middle" dominant-baseline="central" fill="#28c840" font-size="22" font-weight="700">99.7%</text>
                      </svg>
                      <div class="ind-widget-footnote">0.3s detection · <span class="ind-dim">Manual: 2.4 hrs</span></div>
                    </div>
                  </>
                )}

                {/* ── Industry 3: Legal ── */}
                {i === 3 && (
                  <>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Contract Analyzer</div>
                      <div class="ind-feed" data-feed>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">96%</span><span class="ind-feed-text">Non-compete clause — extracted</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-warn">&#9888;</span><span class="ind-feed-text">Liability cap: $2M — flagged</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">94%</span><span class="ind-feed-text">Termination: 90-day notice</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-warn">&#9888;</span><span class="ind-feed-text">IP assignment — ambiguous</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">91%</span><span class="ind-feed-text">Payment terms: Net 30</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">98%</span><span class="ind-feed-text">Governing law: NY — confirmed</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-ok">94%</span><span class="ind-feed-text">Indemnification — standard</span></div>
                        <div class="ind-feed-item"><span class="ind-feed-badge ind-badge-warn">&#9888;</span><span class="ind-feed-text">Force majeure — non-standard</span></div>
                      </div>
                      <div class="ind-widget-footnote">340 pages · analyzed in 4 min</div>
                    </div>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Case Research</div>
                      <div class="ind-hero-num">14</div>
                      <div class="ind-hero-unit">precedents found in 8 seconds</div>
                      <div class="ind-compare" style="margin-top:10px">
                        <div class="ind-compare-row">
                          <span class="ind-compare-label">Manual</span>
                          <div class="ind-compare-track"><div class="ind-compare-fill" style="--bar-w:100%"></div></div>
                          <span class="ind-compare-val">6-8 hrs</span>
                        </div>
                        <div class="ind-compare-row">
                          <span class="ind-compare-label">AI</span>
                          <div class="ind-compare-track"><div class="ind-compare-fill ind-compare-accent" style="--bar-w:1.5%"></div></div>
                          <span class="ind-compare-val">8 sec</span>
                        </div>
                      </div>
                    </div>
                    <div class="ind-widget ind-widget-donut">
                      <div class="ind-widget-label">Revenue Recovery</div>
                      <svg viewBox="0 0 80 80" class="ind-donut" aria-hidden="true">
                        <circle cx="40" cy="40" r="30" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="7"/>
                        <circle cx="40" cy="40" r="30" fill="none" stroke="var(--color-accent)" stroke-width="7" stroke-linecap="round" class="ind-donut-fill" stroke-dasharray="188.5" stroke-dashoffset="188.5" data-donut-fill data-donut-base="33.9" style="--donut-offset:33.9" transform="rotate(-90 40 40)"/>
                        <text x="40" y="37" text-anchor="middle" dominant-baseline="central" fill="var(--color-accent)" font-size="16" font-weight="700">82%</text>
                        <text x="40" y="52" text-anchor="middle" fill="rgba(150,160,180,0.7)" font-size="8">billed</text>
                      </svg>
                      <div class="ind-savings">
                        <span class="ind-savings-value" data-count="47200" data-count-step="100" data-count-format="money-k">$47.2K</span>
                        <span class="ind-savings-label">recovered this quarter</span>
                      </div>
                    </div>
                  </>
                )}

                {/* ── Industry 4: Healthcare Administration ── */}
                {i === 4 && (
                  <>
                    <div class="ind-widget">
                      <div class="ind-widget-label">Schedule Optimization</div>
                      <div class="ind-slots" data-slot-grid>
                        <div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-ai"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div>
                        <div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-ai"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot"></div>
                        <div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-ai"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-ai"></div><div class="ind-slot ind-slot-filled"></div>
                        <div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-ai"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot ind-slot-filled"></div><div class="ind-slot"></div><div class="ind-slot ind-slot-ai"></div>
                      </div>
                      <div class="ind-slot-legend">
                        <span><span class="ind-slot-swatch ind-swatch-filled"></span>Booked</span>

  .ind-panel { display: none; }
  .ind-panel[hidden] { display: none; }
  .ind-panel:not([hidden]) { display: block; }
  .ind-layout { display: grid; grid-template-columns: 2fr 3fr; gap: 24px; align-items: center; }

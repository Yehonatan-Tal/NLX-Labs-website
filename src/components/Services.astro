---
import type { Translations } from "@i18n/types";
import SectionHeading from "./SectionHeading.astro";
import ServiceCard from "./ServiceCard.astro";

interface Props {
  t: Translations["services"];
}

const { t } = Astro.props;

const iconMap = ["Brain", "Search", "Wrench"];
---

<section id="services" class="services-section relative py-24 lg:py-36 px-6 lg:px-12 overflow-hidden noise-texture" style="background:#07080a">
  <!-- Top gradient blend from hero -->
  <div class="absolute top-0 left-0 right-0 h-40 bg-gradient-to-b from-black to-transparent z-[1]" aria-hidden="true"></div>

  <!-- Ambient glow orbs -->
  <div class="absolute inset-0" aria-hidden="true">
    <div
      class="glow-orb animate-float-slow"
      style="width: 500px; height: 380px; top: 12%; right: 15%; background: radial-gradient(ellipse, rgba(224, 104, 90, 0.07) 0%, transparent 70%);"
    ></div>
    <div
      class="glow-orb animate-float-slower"
      style="width: 420px; height: 320px; bottom: 15%; left: 10%; background: radial-gradient(ellipse, rgba(150, 160, 180, 0.04) 0%, transparent 70%);"
    ></div>
  </div>

  <!-- Twinkling stars -->
  <div class="star-field" aria-hidden="true">
    <span class="twinkle-star" style="top:7%;left:65%;animation-duration:5.2s;animation-delay:0.3s"></span>
    <span class="twinkle-star" style="top:34%;left:25%;animation-duration:4.6s;animation-delay:2.7s"></span>
    <span class="twinkle-star" style="top:58%;left:85%;animation-duration:5.0s;animation-delay:1.8s"></span>
    <span class="twinkle-star" style="top:82%;left:42%;animation-duration:4.4s;animation-delay:3.1s"></span>
  </div>

  <div class="relative z-1 mx-auto max-w-[72rem]">
    <SectionHeading title={t.title} subtitle={t.subtitle} dark accent />

    <div class="grid gap-6 lg:gap-8 sm:grid-cols-3" data-animate="stagger-cards">
      {t.items.map((item, i) => (
        <ServiceCard
          icon={iconMap[i]}
          title={item.title}
          description={item.description}
          delay={i * 120}
        />
      ))}
    </div>

    <div class="mt-16 lg:mt-20 flex justify-center" data-animate="fade-in">
      <p class="relative max-w-[42rem] text-center text-[1.0625rem] lg:text-[1.125rem] italic leading-[1.7] text-dark-text-secondary before:absolute before:-top-6 before:left-1/2 before:-translate-x-1/2 before:w-12 before:h-px before:bg-white/10">
        {t.positioningStatement}
      </p>
    </div>
  </div>
</section>

<style>
  /* Sparse starfield — unique positions */
  .services-section::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(1px 1px at 14% 33%, rgba(255,255,255,0.45), transparent),
      radial-gradient(1px 1px at 58% 78%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1px 1px at 81% 21%, rgba(255,255,255,0.50), transparent),
      radial-gradient(1px 1px at 36% 57%, rgba(255,255,255,0.30), transparent),
      radial-gradient(1px 1px at 93% 48%, rgba(255,255,255,0.40), transparent),
      radial-gradient(1px 1px at 19% 76%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1px 1px at 64% 14%, rgba(255,255,255,0.45), transparent),
      radial-gradient(1.5px 1.5px at 42% 88%, rgba(255,255,255,0.40), transparent),
      radial-gradient(1.5px 1.5px at 88% 62%, rgba(255,255,255,0.50), transparent);
    background-size:
      281px 319px,
      339px 267px,
      267px 301px,
      301px 281px,
      319px 339px,
      355px 259px,
      259px 355px,
      403px 371px,
      371px 403px;
  }

  .star-field {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .twinkle-star {
    position: absolute;
    display: block;
    width: 1.5px;
    height: 1.5px;
    border-radius: 50%;
    background: white;
    opacity: 0.25;
    animation: twinkle ease-in-out infinite;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0.2; box-shadow: none; }
    50% { opacity: 0.85; box-shadow: 0 0 3px rgba(255,255,255,0.4); }
  }

  @media (prefers-reduced-motion: reduce) {
    .twinkle-star { animation: none; opacity: 0.4; }
  }

  /* Softer starlight-tinted title */
  .services-section :global(h2) {
    color: #B0C0D4;
  }
</style>

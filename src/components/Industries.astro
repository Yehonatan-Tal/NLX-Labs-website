---
import type { Translations } from "@i18n/types";
import SectionHeading from "./SectionHeading.astro";
import IndustryDashboards from "./IndustryDashboards.astro";

interface Props {
  t: Translations["industries"];
}

const { t } = Astro.props;
---

<section id="industries" class="industries-section relative pt-10 pb-24 lg:pt-14 lg:pb-36 px-6 lg:px-12 overflow-hidden noise-texture" style="background:#07080a">
  <!-- Ambient glow orbs -->
  <div class="absolute inset-0" aria-hidden="true">
    <div
      class="glow-orb animate-float-slow"
      style="width: 450px; height: 350px; top: 15%; right: 12%; background: radial-gradient(ellipse, rgba(224, 104, 90, 0.07) 0%, transparent 70%);"
    ></div>
    <div
      class="glow-orb animate-float-slower"
      style="width: 400px; height: 300px; bottom: 20%; left: 8%; background: radial-gradient(ellipse, rgba(150, 160, 180, 0.04) 0%, transparent 70%);"
    ></div>
  </div>

  <!-- Twinkling stars -->
  <div class="star-field" aria-hidden="true">
    <span class="twinkle-star" style="top:14%;left:75%;animation-duration:5.1s;animation-delay:0.8s"></span>
    <span class="twinkle-star" style="top:42%;left:18%;animation-duration:4.5s;animation-delay:2.9s"></span>
    <span class="twinkle-star" style="top:71%;left:88%;animation-duration:5.6s;animation-delay:1.5s"></span>
    <span class="twinkle-star" style="top:89%;left:35%;animation-duration:4.3s;animation-delay:3.4s"></span>
  </div>

  <div class="relative z-1 mx-auto max-w-[72rem]">
    <div class="industries-heading">
      <SectionHeading title={t.title} subtitle={t.subtitle} dark accent />
    </div>

    <IndustryDashboards items={t.items} />

    <div class="mx-auto mt-6 lg:mt-8 max-w-[48rem] text-center" data-animate="fade-in">
      <p class="text-[1.0625rem] leading-[1.7] text-dark-text-secondary">
        {t.closingStatement}
      </p>
      <a href="#contact" class="ind-closing-cta">
        {t.closingCta}
        <svg class="ind-cta-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </div>

</section>

<style>
  /* Sparse starfield — unique positions from Process */
  .industries-section::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(1px 1px at 12% 28%, rgba(255,255,255,0.45), transparent),
      radial-gradient(1px 1px at 55% 73%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1px 1px at 78% 15%, rgba(255,255,255,0.50), transparent),
      radial-gradient(1px 1px at 33% 61%, rgba(255,255,255,0.30), transparent),
      radial-gradient(1px 1px at 89% 44%, rgba(255,255,255,0.40), transparent),
      radial-gradient(1px 1px at 21% 82%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1px 1px at 67% 38%, rgba(255,255,255,0.45), transparent),
      radial-gradient(1.5px 1.5px at 44% 91%, rgba(255,255,255,0.40), transparent),
      radial-gradient(1.5px 1.5px at 92% 56%, rgba(255,255,255,0.50), transparent);
    background-size:
      283px 317px,
      337px 271px,
      271px 299px,
      299px 283px,
      317px 337px,
      353px 257px,
      257px 353px,
      401px 373px,
      373px 401px;
  }

  .star-field {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .twinkle-star {
    position: absolute;
    display: block;
    width: 1.5px;
    height: 1.5px;
    border-radius: 50%;
    background: white;
    opacity: 0.25;
    animation: twinkle ease-in-out infinite;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0.2; box-shadow: none; }
    50% { opacity: 0.85; box-shadow: 0 0 3px rgba(255,255,255,0.4); }
  }

  @media (prefers-reduced-motion: reduce) {
    .twinkle-star { animation: none; opacity: 0.4; }
  }

  /* Tighten heading bottom margin so pills feel connected */
  .industries-heading :global(div[data-animate]) {
    margin-bottom: 2rem;
  }
  @media (min-width: 1024px) {
    .industries-heading :global(div[data-animate]) {
      margin-bottom: 2.5rem;
    }
  }

  /* Closing CTA */
  .ind-closing-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 1rem;
    padding: 10px 24px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-accent);
    background: rgba(224, 104, 90, 0.08);
    border: 1px solid rgba(224, 104, 90, 0.2);
    border-radius: 9999px;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .ind-closing-cta:hover {
    background: rgba(224, 104, 90, 0.14);
    border-color: rgba(224, 104, 90, 0.35);
    box-shadow: 0 0 40px rgba(224, 104, 90, 0.18), 0 0 80px rgba(224, 104, 90, 0.08);
  }
  .ind-closing-cta:active {
    transform: scale(0.96);
    transition: transform 0.1s ease;
  }
  .ind-cta-arrow {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    animation: ind-nudge-x 3s ease-in-out infinite;
  }
  :global([dir="rtl"]) .ind-cta-arrow {
    rotate: 180deg;
  }
  @keyframes ind-nudge-x {
    0%, 70% { transform: translateX(0); }
    80%     { transform: translateX(4px); }
    90%     { transform: translateX(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ind-cta-arrow { animation: none; }
    .ind-closing-cta:active { transform: none; }
  }

  /* Softer starlight-tinted title */
  .industries-section :global(h2) {
    color: #B0C0D4;
  }
</style>

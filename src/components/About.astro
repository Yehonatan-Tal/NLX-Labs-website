---
import type { Translations } from "@i18n/types";
import SectionHeading from "./SectionHeading.astro";
import PrincipleCard from "./PrincipleCard.astro";
import FounderBio from "./FounderBio.astro";

interface Props {
  t: Translations["about"];
}

const { t } = Astro.props;
---

<section id="about" class="about-section relative pt-10 pb-24 lg:pt-14 lg:pb-36 px-6 lg:px-12 overflow-hidden noise-texture" style="background:#07080a">
  <!-- Ambient glow orbs -->
  <div class="absolute inset-0" aria-hidden="true">
    <div
      class="glow-orb animate-float-slow"
      style="width: 420px; height: 320px; top: 20%; left: 55%; background: radial-gradient(ellipse, rgba(224, 104, 90, 0.06) 0%, transparent 70%);"
    ></div>
    <div
      class="glow-orb animate-float-slower"
      style="width: 380px; height: 280px; bottom: 15%; right: 60%; background: radial-gradient(ellipse, rgba(150, 160, 180, 0.04) 0%, transparent 70%);"
    ></div>
  </div>

  <!-- Twinkling stars -->
  <div class="star-field" aria-hidden="true">
    <span class="twinkle-star" style="top:11%;left:42%;animation-duration:4.9s;animation-delay:1.1s"></span>
    <span class="twinkle-star" style="top:35%;left:8%;animation-duration:5.4s;animation-delay:3.2s"></span>
    <span class="twinkle-star" style="top:62%;left:92%;animation-duration:4.2s;animation-delay:0.4s"></span>
    <span class="twinkle-star" style="top:86%;left:55%;animation-duration:5.8s;animation-delay:2.1s"></span>
  </div>

  <div class="relative z-1 mx-auto max-w-[72rem]">
    <SectionHeading title={t.title} subtitle={t.subtitle} dark accent />

    <p class="mx-auto max-w-[48rem] text-center text-[1.0625rem] lg:text-[1.125rem] leading-[1.75] text-dark-text-secondary" data-animate="fade-in">
      {t.narrative}
    </p>

    <div class="mt-20 lg:mt-24">
      <!-- Toggle pill -->
      <div class="flex items-center justify-center mb-12 lg:mb-16" data-animate="fade-up">
        <div class="abt-toggle" role="tablist">
          <button
            id="abt-tab-principles"
            class="abt-toggle-btn abt-toggle-active"
            role="tab"
            aria-selected="true"
            aria-controls="abt-panel-principles"
          >
            {t.principlesTab}
          </button>
          <button
            id="abt-tab-founder"
            class="abt-toggle-btn"
            role="tab"
            aria-selected="false"
            aria-controls="abt-panel-founder"
          >
            {t.founderTab}
          </button>
          <div class="abt-toggle-indicator" aria-hidden="true"></div>
        </div>
      </div>

      <!-- Panels wrapper (sets height for smooth transitions) -->
      <div class="abt-panels">
        <!-- Principles panel -->
        <div
          id="abt-panel-principles"
          class="abt-panel abt-panel-active"
          role="tabpanel"
          aria-labelledby="abt-tab-principles"
        >
          <div class="grid gap-6 lg:gap-8 sm:grid-cols-2 lg:grid-cols-3" data-animate="stagger-cards">
            {t.principles.map((principle, i) => (
              <PrincipleCard
                index={i}
                title={principle.title}
                description={principle.description}
                delay={i * 100}
              />
            ))}
          </div>
        </div>

        <!-- Founder panel -->
        <div
          id="abt-panel-founder"
          class="abt-panel"
          role="tabpanel"
          aria-labelledby="abt-tab-founder"
          hidden
        >
          <FounderBio
            name={t.founder.name}
            role={t.founder.role}
            bio={t.founder.bio}
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom gradient divider -->
  <div class="absolute bottom-0 left-0 right-0 section-divider" aria-hidden="true"></div>
</section>

<style>
  /* ── Starfield (unique from Process & Industries) ── */
  .about-section::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(1px 1px at 8% 19%, rgba(255,255,255,0.45), transparent),
      radial-gradient(1px 1px at 43% 67%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1px 1px at 72% 11%, rgba(255,255,255,0.50), transparent),
      radial-gradient(1px 1px at 27% 83%, rgba(255,255,255,0.30), transparent),
      radial-gradient(1px 1px at 85% 52%, rgba(255,255,255,0.40), transparent),
      radial-gradient(1px 1px at 15% 47%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1px 1px at 58% 25%, rgba(255,255,255,0.45), transparent),
      radial-gradient(1.5px 1.5px at 36% 78%, rgba(255,255,255,0.40), transparent),
      radial-gradient(1.5px 1.5px at 94% 34%, rgba(255,255,255,0.50), transparent);
    background-size:
      289px 323px,
      343px 269px,
      269px 307px,
      307px 289px,
      323px 343px,
      359px 261px,
      261px 359px,
      407px 379px,
      379px 407px;
  }

  .star-field {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .twinkle-star {
    position: absolute;
    display: block;
    width: 1.5px;
    height: 1.5px;
    border-radius: 50%;
    background: white;
    opacity: 0.25;
    animation: twinkle ease-in-out infinite;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0.2; box-shadow: none; }
    50% { opacity: 0.85; box-shadow: 0 0 3px rgba(255,255,255,0.4); }
  }

  @media (prefers-reduced-motion: reduce) {
    .twinkle-star { animation: none; opacity: 0.4; }
  }

  .about-section :global(h2) {
    color: #B0C0D4;
  }

  /* ── Toggle pill ── */
  .abt-toggle {
    position: relative;
    display: inline-flex;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 9999px;
    padding: 4px;
  }

  .abt-toggle-btn {
    position: relative;
    z-index: 1;
    padding: 0.5rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-dark-text-secondary);
    background: none;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: color 0.3s ease;
    white-space: nowrap;
  }

  .abt-toggle-btn:hover {
    color: var(--color-dark-text);
  }

  .abt-toggle-btn.abt-toggle-active {
    color: var(--color-dark-text);
  }

  .abt-toggle-indicator {
    position: absolute;
    top: 4px;
    bottom: 4px;
    left: 0;
    width: 0;
    background: rgba(224, 104, 90, 0.12);
    border: 1px solid rgba(224, 104, 90, 0.2);
    border-radius: 9999px;
    transition: left 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  /* ── Panels ── */
  .abt-panels {
    position: relative;
    overflow: hidden;
  }

  .abt-panel {
    opacity: 1;
    transition: opacity 0.35s ease;
  }

  .abt-panel[hidden] {
    display: none;
  }
</style>

<script>
  function initAboutToggle() {
    const toggle = document.querySelector('.abt-toggle') as HTMLElement | null;
    const indicator = document.querySelector('.abt-toggle-indicator') as HTMLElement | null;
    const btnPrinciples = document.getElementById('abt-tab-principles');
    const btnFounder = document.getElementById('abt-tab-founder');
    const panelPrinciples = document.getElementById('abt-panel-principles');
    const panelFounder = document.getElementById('abt-panel-founder');

    if (!toggle || !indicator || !btnPrinciples || !btnFounder || !panelPrinciples || !panelFounder) return;

    let animating = false;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const duration = prefersReduced ? 0 : 300;

    function moveIndicator(btn: HTMLElement, animate: boolean) {
      const toggleRect = toggle!.getBoundingClientRect();
      const btnRect = btn.getBoundingClientRect();
      const offsetLeft = btnRect.left - toggleRect.left;

      if (!animate) {
        indicator!.style.transition = 'none';
      }
      indicator!.style.left = `${offsetLeft}px`;
      indicator!.style.width = `${btnRect.width}px`;
      if (!animate) {
        void indicator!.offsetHeight;
        indicator!.style.removeProperty('transition');
      }
    }

    // Set initial position without animation
    moveIndicator(btnPrinciples, false);

    function switchTo(target: 'principles' | 'founder') {
      if (animating) return;

      const isFounder = target === 'founder';
      const outPanel = isFounder ? panelPrinciples : panelFounder;
      const inPanel = isFounder ? panelFounder : panelPrinciples;
      const activeBtn = isFounder ? btnFounder : btnPrinciples;
      const inactiveBtn = isFounder ? btnPrinciples : btnFounder;

      // Move indicator to active button
      moveIndicator(activeBtn, true);

      activeBtn.classList.add('abt-toggle-active');
      activeBtn.setAttribute('aria-selected', 'true');
      inactiveBtn.classList.remove('abt-toggle-active');
      inactiveBtn.setAttribute('aria-selected', 'false');

      if (duration === 0) {
        outPanel.hidden = true;
        inPanel.hidden = false;
        return;
      }

      animating = true;

      // Fade out current panel
      outPanel.style.opacity = '0';
      outPanel.style.transform = 'translateY(8px)';
      outPanel.style.transition = `opacity ${duration}ms ease, transform ${duration}ms ease`;

      setTimeout(() => {
        outPanel.hidden = true;
        outPanel.style.removeProperty('transform');

        // Prepare incoming panel
        inPanel.style.opacity = '0';
        inPanel.style.transform = 'translateY(8px)';
        inPanel.hidden = false;

        // Force reflow
        void inPanel.offsetHeight;

        // Fade in
        inPanel.style.transition = `opacity ${duration}ms ease, transform ${duration}ms ease`;
        inPanel.style.opacity = '1';
        inPanel.style.transform = 'translateY(0)';

        setTimeout(() => {
          // Clean up inline styles
          inPanel.style.removeProperty('opacity');
          inPanel.style.removeProperty('transform');
          inPanel.style.removeProperty('transition');
          outPanel.style.removeProperty('opacity');
          outPanel.style.removeProperty('transition');
          animating = false;
        }, duration);
      }, duration);
    }

    btnPrinciples.addEventListener('click', () => switchTo('principles'));
    btnFounder.addEventListener('click', () => switchTo('founder'));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAboutToggle);
  } else {
    initAboutToggle();
  }
</script>

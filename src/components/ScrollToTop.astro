---
import { ArrowUp } from "@lucide/astro";

interface Props {
  label: string;
}

const { label } = Astro.props;
---

<button
  id="scroll-to-top"
  aria-label={label}
  class="fixed bottom-6 end-6 z-40 flex h-11 w-11 items-center justify-center rounded-[0.625rem] bg-accent text-white opacity-0 shadow-lg transition-all duration-250 hover:bg-accent-hover pointer-events-none"
  style="transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);"
>
  <ArrowUp size={20} />
</button>

<script>
  const btn = document.getElementById("scroll-to-top");
  if (btn) {
    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          if (window.scrollY > window.innerHeight) {
            btn.style.opacity = "1";
            btn.style.pointerEvents = "auto";
          } else {
            btn.style.opacity = "0";
            btn.style.pointerEvents = "none";
          }
          ticking = false;
        });
        ticking = true;
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    btn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>

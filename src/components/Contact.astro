---
import type { Translations } from "@i18n/types";
import type { Locale } from "@i18n/types";
import SectionHeading from "./SectionHeading.astro";
import ContactForm from "./ContactForm.astro";
import { Mail } from "@lucide/astro";

interface Props {
  t: Translations["contact"];
  locale: Locale;
}

const { t, locale } = Astro.props;
---

<section id="contact" class="relative bg-light-bg py-24 lg:py-36 px-6 lg:px-12 overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] rounded-full opacity-30" style="background: radial-gradient(ellipse, rgba(224, 104, 90, 0.06) 0%, transparent 65%);" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-[72rem]">
    <SectionHeading title={t.title} subtitle={t.subtitle} accent />

    <div class="grid gap-12 lg:gap-16 lg:grid-cols-[2fr_3fr] items-start">
      <div data-animate="fade-up">
        <p class="text-[1.0625rem] leading-[1.75] text-text-primary max-w-[65ch]">
          {t.intro}
        </p>

        <div class="mt-8 elevated-card flex items-start gap-4 rounded-[0.75rem] p-5">
          <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-[0.5rem] bg-accent/[0.08]">
            <Mail size={20} class="text-accent" />
          </div>
          <div>
            <p class="text-[0.875rem] text-text-secondary">
              {t.emailLabel}
            </p>
            <a
              href="mailto:contact@nlxlabs.co.il"
              class="mt-1 inline-flex items-center gap-1.5 text-[1.0625rem] text-accent font-medium transition-all duration-150 hover:underline hover:underline-offset-4"
            >
              contact@nlxlabs.co.il
            </a>
          </div>
        </div>

        <a
          href="https://wa.me/972509927121?text=Hi%2C%20I'm%20interested%20in%20learning%20more%20about%20NLX%20Labs'%20AI%20solutions."
          target="_blank"
          rel="noopener noreferrer"
          class="whatsapp-btn mt-4 inline-flex w-full items-center justify-center gap-2.5 rounded-[0.75rem] px-5 py-3.5 text-[0.9375rem] font-semibold text-white transition-all duration-200"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="flex-shrink-0">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" fill="currentColor"/>
            <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.96 7.96 0 01-4.11-1.14l-.29-.174-3.01.79.81-2.95-.19-.3A7.96 7.96 0 014 12c0-4.42 3.58-8 8-8s8 3.58 8 8-3.58 8-8 8z" fill="currentColor"/>
          </svg>
          {t.whatsappLabel}
        </a>
      </div>

      <div class="elevated-card rounded-[0.75rem] p-8 lg:p-10" data-animate="fade-up">
        <ContactForm t={t.form} validation={t.validation} locale={locale} />
      </div>
    </div>
  </div>
</section>

<style>
  .whatsapp-btn {
    background-color: #25D366;
    box-shadow:
      0 1px 3px rgba(37, 211, 102, 0.2),
      0 4px 12px rgba(37, 211, 102, 0.1);
  }

  .whatsapp-btn:hover {
    background-color: #1fbd59;
    box-shadow:
      0 2px 6px rgba(37, 211, 102, 0.3),
      0 8px 20px rgba(37, 211, 102, 0.15);
    transform: translateY(-1px);
  }

  .whatsapp-btn:active {
    transform: translateY(0);
    background-color: #1aab50;
  }
</style>

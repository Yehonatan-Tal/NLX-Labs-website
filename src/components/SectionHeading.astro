---
import logo from "@assets/logo.svg";

interface Props {
  title: string;
  subtitle?: string;
  align?: "center" | "start";
  dark?: boolean;
  accent?: boolean;
}

const { title, subtitle, align = "center", dark = false, accent = false } = Astro.props;
const alignClass = align === "center" ? "text-center" : "text-start";
const titleColor = dark ? "text-dark-text" : "text-text-primary";
const subtitleColor = dark ? "text-dark-text-secondary" : "text-text-secondary";
---

<div class={`mb-14 lg:mb-20 ${alignClass}`} data-animate="fade-up">
  {accent && (
    <div class="section-divider-accent" aria-hidden="true">
      <div class="section-divider-line"></div>
      <img src={logo.src} alt="" class="section-divider-logo" width="90" height="18" />
      <div class="section-divider-line"></div>
    </div>
  )}
  <h2
    class={`text-[1.875rem] md:text-[2.25rem] lg:text-[2.75rem] font-bold leading-[1.15] tracking-[-0.025em] ${titleColor}`}
    style="text-wrap: balance;"
  >
    {title}
  </h2>
  {subtitle && (
    <p class={`mt-5 text-[1rem] lg:text-[1.125rem] leading-[1.65] ${subtitleColor} max-w-[36rem] ${align === "center" ? "mx-auto" : ""}`}>
      {subtitle}
    </p>
  )}
</div>

<style>
  .section-divider-accent {
    display: flex;
    align-items: center;
    width: 80vw;
    margin-left: calc(50% - 40vw);
    margin-bottom: 6rem;
  }

  .section-divider-line {
    flex: 1;
    height: 0;
    border-top: 1px solid var(--color-accent);
    border-image: linear-gradient(90deg, transparent, var(--color-accent), transparent) 1;
    box-shadow: 0 0 6px rgba(224, 104, 90, 0.3);
  }

  .section-divider-logo {
    flex-shrink: 0;
    width: 90px;
    height: auto;
    margin: 0 16px;
    filter:
      drop-shadow(0 0 4px rgba(224, 104, 90, 0.9))
      drop-shadow(0 0 12px rgba(224, 104, 90, 0.6))
      drop-shadow(0 0 28px rgba(224, 104, 90, 0.3));
  }
</style>

---
import { Brain, Search, Wrench } from "@lucide/astro";

interface Props {
  icon: string;
  title: string;
  description: string;
  delay?: number;
}

const { icon, title, description, delay = 0 } = Astro.props;

const icons: Record<string, any> = { Brain, Search, Wrench };
const IconComponent = icons[icon];
---

<div
  class="group glass-card rounded-[0.75rem] p-8 lg:p-10"
  style={`transition-delay: ${delay}ms;`}
>
  <div class="relative flex h-14 w-14 items-center justify-center rounded-[0.75rem] bg-accent/[0.08] transition-all duration-300 group-hover:bg-accent/[0.12] group-hover:shadow-[0_0_20px_rgba(224,104,90,0.12)]">
    {IconComponent && <IconComponent size={26} class="text-accent" />}
  </div>
  <h3 class="mt-6 text-[1.25rem] lg:text-[1.375rem] font-semibold leading-[1.25] tracking-[-0.015em] text-dark-text">
    {title}
  </h3>
  <p class="mt-3 text-[0.9375rem] lg:text-base leading-[1.7] text-dark-text-secondary">
    {description}
  </p>
</div>

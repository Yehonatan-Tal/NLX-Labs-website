---
import type { Locale, Translations } from "@i18n/types";
import LanguageToggle from "./LanguageToggle.astro";
import { Menu } from "@lucide/astro";
import logo from "@assets/logo.svg";

interface Props {
  t: Translations["nav"];
  locale: Locale;
}

const { t, locale } = Astro.props;

const navLinks = [
  { href: "#services", label: t.services },
  { href: "#process", label: t.process },
  { href: "#industries", label: t.industries },
  { href: "#about", label: t.about },
];

const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : `${raw}/`;
const homeHref = locale === "he" ? `${base}he/` : base;
---

<div id="site-nav" class="fixed top-0 inset-x-0 z-50 px-4 pt-4 transition-[padding] duration-300">
  <header class="nav-pill mx-auto max-w-[72rem] rounded-2xl transition-all duration-300">
    <nav
      data-nav
      dir="ltr"
      class="relative flex h-[3.75rem] items-center justify-between px-6 lg:px-7"
      aria-label="Main navigation"
    >
      <!-- Logo (left) -->
      <a href={homeHref} class="flex-shrink-0 relative z-10" aria-label="NLX-labs home">
        <img src={logo.src} alt="NLX Labs" class="h-[2.14rem] w-auto" />
      </a>

      <!-- Centered nav links -->
      <div class="hidden lg:flex absolute inset-x-0 justify-center pointer-events-none">
        <div class="pointer-events-auto flex items-center gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="nav-link rounded-lg px-4 py-2 text-[0.9375rem] font-medium text-white/60 transition-all duration-150 hover:text-white hover:bg-white/[0.06]"
              data-section={link.href.replace("#", "")}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Right actions -->
      <div dir="ltr" class="flex items-center gap-3 relative z-10">
        <a
          href="#contact"
          class="hidden lg:inline-flex items-center justify-center rounded-lg bg-white/[0.1] border border-white/[0.08] px-[1.1rem] py-2 text-[0.875rem] font-medium text-white transition-all duration-200 hover:bg-white/[0.16] hover:border-white/[0.14]"
        >
          {t.contact}
        </a>
        <button
          id="menu-toggle"
          class="flex lg:hidden items-center justify-center w-[2.7rem] h-[2.7rem] text-white"
          aria-label={t.menuOpen}
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <Menu size={24} />
        </button>
        <LanguageToggle locale={locale} label={t.languageToggle} />
      </div>
    </nav>
  </header>
</div>

<script>
  const nav = document.getElementById("site-nav");
  if (nav) {
    // Scroll spy
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll(".nav-link");

    const spyObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navLinks.forEach((link) => {
              const linkSection = (link as HTMLElement).dataset.section;
              if (linkSection === entry.target.id) {
                link.classList.add("nav-link-active");
              } else {
                link.classList.remove("nav-link-active");
              }
            });
          }
        });
      },
      { threshold: 0.3, rootMargin: "-80px 0px -50% 0px" }
    );

    sections.forEach((section) => spyObserver.observe(section));
  }
</script>

<style>
  .nav-pill {
    background: rgba(21, 26, 35, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    box-shadow:
      0 0 0 0.5px rgba(255, 255, 255, 0.04),
      0 4px 24px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  #site-nav.nav-scrolled .nav-pill {
    background: rgba(21, 26, 35, 0.6);
    border-color: rgba(255, 255, 255, 0.06);
    box-shadow:
      0 0 0 0.5px rgba(255, 255, 255, 0.03),
      0 8px 32px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .nav-link-active {
    color: white !important;
    background: rgba(255, 255, 255, 0.08);
  }
</style>

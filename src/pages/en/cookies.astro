---
import { getTranslations, getDirection } from "@i18n/i18n";
import Layout from "@layouts/Layout.astro";
import Nav from "@components/Nav.astro";
import MobileMenu from "@components/MobileMenu.astro";
import Footer from "@components/Footer.astro";

const locale = "en" as const;
const t = getTranslations(locale);
const dir = getDirection(locale);
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : `${raw}/`;
---

<Layout lang={locale} dir={dir} meta={t.meta} currentUrl={Astro.url}>
  <Nav t={t.nav} locale={locale} />
  <MobileMenu t={t.nav} locale={locale} />
  <main id="main-content" class="pt-24 pb-16 lg:pb-24 px-6 lg:px-12">
    <div class="mx-auto max-w-[48rem]">
      <h1 class="text-[1.75rem] lg:text-[2.5rem] font-bold leading-[1.2] tracking-[-0.02em] text-text-primary" style="text-wrap: balance;">
        {t.cookies.title}
      </h1>
      <p class="mt-3 text-[0.875rem] text-text-secondary">{t.cookies.lastUpdated}</p>
      <div
        class="mt-8 prose prose-gray max-w-none [&_h2]:mt-8 [&_h2]:mb-3 [&_h2]:text-[1.25rem] [&_h2]:font-semibold [&_h2]:text-text-primary [&_p]:text-[1.0625rem] [&_p]:leading-[1.7] [&_p]:text-text-secondary [&_p]:mb-4"
        set:html={t.cookies.content}
      />
      <div class="mt-12">
        <a
          href={`${base}en/`}
          class="inline-flex items-center gap-2 text-accent font-medium transition-all duration-150 hover:underline hover:underline-offset-4"
        >
          <svg class="h-4 w-4 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
          </svg>
          Back to Home
        </a>
      </div>
    </div>
  </main>
  <Footer t={t} locale={locale} />
</Layout>

---
import { getLocaleFromUrl, getTranslations, getDirection } from "@i18n/i18n";
import Layout from "@layouts/Layout.astro";
import Button from "@components/Button.astro";

const locale = getLocaleFromUrl(Astro.url);
const t = getTranslations(locale);
const dir = getDirection(locale);
const raw = import.meta.env.BASE_URL;
const base = raw.endsWith("/") ? raw : `${raw}/`;
---

<Layout lang={locale} dir={dir} meta={t.meta} currentUrl={Astro.url}>
  <main class="flex min-h-screen items-center justify-center px-6 lg:px-12">
    <div class="text-center">
      <p class="text-[5rem] lg:text-[8rem] font-bold leading-none text-accent/20">404</p>
      <h1 class="mt-4 text-[1.75rem] lg:text-[2.5rem] font-bold tracking-[-0.02em] text-text-primary">
        {t.notFound.title}
      </h1>
      <p class="mt-3 text-[1.0625rem] text-text-secondary max-w-[40rem] mx-auto">
        {t.notFound.message}
      </p>
      <div class="mt-8">
        <Button variant="primary" href={base}>
          {t.notFound.backHome}
        </Button>
      </div>
    </div>
  </main>
</Layout>

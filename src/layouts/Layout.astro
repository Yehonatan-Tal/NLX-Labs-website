---
import type { Locale, Translations } from "@i18n/types";
import SEOHead from "@components/SEOHead.astro";
import JsonLd from "@components/JsonLd.astro";
import "@styles/global.css";

interface Props {
  lang: Locale;
  dir: "rtl" | "ltr";
  meta: Translations["meta"];
  currentUrl: URL;
}

const { lang, dir, meta, currentUrl } = Astro.props;
const skipLabel = lang === "he" ? "דילוג לתוכן הראשי" : "Skip to main content";
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rubik:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&family=Noto+Sans+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <SEOHead meta={meta} locale={lang} currentUrl={currentUrl} />
    <JsonLd locale={lang} />
  </head>
  <body class="min-h-screen bg-white antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:start-4 focus:z-[100] focus:rounded-lg focus:bg-accent focus:px-4 focus:py-2 focus:text-white focus:outline-none"
    >
      {skipLabel}
    </a>
    <slot />
    <script>
      import { initAnimations } from "../scripts/animations";

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initAnimations);
      } else {
        initAnimations();
      }
    </script>
  </body>
</html>
